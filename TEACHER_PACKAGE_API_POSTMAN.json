{
  "info": {
    "_postman_id": "teacher-package-api-collection",
    "name": "Teacher Package Management API",
    "description": "API برای ایجاد و مدیریت بسه‌های معلم",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Get Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set('access_token', jsonData.access);",
                  "  pm.environment.set('refresh_token', jsonData.refresh);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"teacher1\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/token/",
              "host": ["{{base_url}}"],
              "path": ["api", "token"]
            }
          }
        }
      ]
    },
    {
      "name": "Packages",
      "item": [
        {
          "name": "Create Package",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Python Advanced\",\n  \"description\": \"دوره پیشرفته پایتون\",\n  \"total_sessions\": 12,\n  \"total_price\": \"1200000\",\n  \"teaching_subjects\": [1, 2],\n  \"has_installment\": true,\n  \"is_active\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/teacher/packages/",
              "host": ["{{base_url}}"],
              "path": ["api", "teacher", "packages"]
            }
          }
        },
        {
          "name": "List Packages",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  if (jsonData.data.length > 0) {",
                  "    pm.environment.set('package_id', jsonData.data[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/teacher/packages/",
              "host": ["{{base_url}}"],
              "path": ["api", "teacher", "packages"]
            }
          }
        },
        {
          "name": "Get Package Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/teacher/packages/{{package_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "teacher", "packages", "{{package_id}}", ""]
            }
          }
        },
        {
          "name": "Update Package",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Python Advanced (Updated)\",\n  \"total_sessions\": 14,\n  \"total_price\": \"1400000\",\n  \"is_active\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/teacher/packages/{{package_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "teacher", "packages", "{{package_id}}", ""]
            }
          }
        },
        {
          "name": "Delete Package",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/teacher/packages/{{package_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "teacher", "packages", "{{package_id}}", ""]
            }
          }
        }
      ]
    },
    {
      "name": "Installments",
      "item": [
